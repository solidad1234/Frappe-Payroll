etter spacing */\\n        }\\n        .bold-text {\\n            font-weight: bold; /* Make the text bold */\\n        }\\n    </style>\\n</head>\\n<body>\\n    <table id=\\\"earning-table\\\">\\n        <thead>\\n            <tr>\\n                <th style=\\\"width: 50%\\\">Component</th>\\n                <th style=\\\"width: 15%\\\">Amount</th>\\n            </tr>\\n        </thead>\\n        <tbody>\\n    {% for item in doc.earnings | sort(attribute='amount', reverse=True) %}\\n    <tr>\\n        <td>{{ item.salary_component }}\\n        {% if item.salary_component == 'Basic Pay' %} (Inclusive of House Allowance) {% endif %}</td>\\n        <td>{{ '{:,.2f}'.format(item.amount) }}</td>\\n    </tr>\\n    {% endfor %}\\n    \\n    \\n</tbody>\\n    </table>\\n</body>\\n</html>\\n\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n    <meta charset=\\\"UTF-8\\\">\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n    <style>\\n        /* Unique CSS ID for the container */\\n        #UniqueReceiptDetailsContainer {\\n            justify-content: space-between;\\n            text-align: right; /* Align the entire container text to the right */\\n            width: 100%; /* Set a max width to control the layout */\\n            font-family: Arial, sans-serif; /* Set a font for consistency */\\n            margin-right: 0; /* Ensure the container is aligned to the far right */\\n        }\\n\\n        /* Unique class for the table */\\n        .uniqueReceiptTable {\\n            border-collapse: collapse;\\n            width: 100%; /* Ensure the table takes full width */\\n            margin-top: 10px; /* Add some spacing at the top */\\n        }\\n\\n        /* Style for table cells */\\n        .uniqueReceiptTable td {\\n            font-size: 12px;\\n            text-align: right; /* Align text to the right within table cells */\\n            padding: 1px; /* Add some padding for better readability */\\n            white-space: nowrap; /* Prevent text from wrapping to the next line */\\n        }\\n        .bold-text {\\n            font-weight: bold; /* Make the text bold */\\n        }\\n    </style>\\n</head>\\n<body style = \\\"\\\">\\n    <div id=\\\"UniqueReceiptDetailsContainer\\\">\\n        <table class=\\\"uniqueReceiptTable\\\">\\n            <tr>\\n                <td class=\\\"bold-text\\\">Gross Pay:</td>\\n                <td>{{ frappe.format(doc.gross_pay, {'fieldtype': 'Currency'}) }}</td>\\n            </tr>\\n            <!--<tr>-->\\n            <!--    <td class=\\\"bold-text\\\">Total Deduction:</td>-->\\n            <!--    <td>{{ frappe.format(doc.total_deduction, {'fieldtype': 'Currency'}) }}</td>-->\\n            <!--</tr>-->\\n            <!-- <tr>-->\\n            <!--    <td class=\\\"bold-text\\\">Net Pay:</td>-->\\n            <!--    <td>{{ frappe.format(doc.net_pay, {'fieldtype': 'Currency'}) }}</td>-->\\n            <!--</tr>-->\\n        </table>\\n    </div>\\n</body>\\n</html>\\n\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<p><strong>Deductions</strong></p>\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n    <meta charset=\\\"UTF-8\\\">\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n    <style>\\n        #deduction-table {\\n            font-size: 12px;\\n            height: 200px; /