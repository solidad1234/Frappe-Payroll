ollapse: collapse;\\n            width: 100%; /* Ensure the table takes full width */\\n            margin-top: 10px; /* Add some spacing at the top */\\n        }\\n\\n        /* Style for table cells */\\n        .receiptTable td {\\n            font-size: 10px;\\n            text-align: left; /* Align text to the left within table cells */\\n            padding: 1px; /* Add some padding for better readability */\\n            white-space: nowrap; /* Prevent text from wrapping to the next line */\\n        }\\n       \\n    </style>\\n</head>\\n<body>\\n    <div id=\\\"receiptDetailsContainer\\\">\\n        <table class=\\\"receiptTable\\\">\\n            <tr>\\n                <td>Employee Number:</td>\\n                <td>{{doc.employee}}</td>\\n            </tr>\\n            <tr>\\n                <td>Full Name:</td>\\n                <td>{{doc.employee_name}}</td>\\n            </tr>\\n            <tr>\\n                <td></td>\\n                <td></td>\\n            </tr>\\n            <tr>\\n               \\n            </tr>\\n        </table>\\n    </div>\\n</body>\\n</html>\\n\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n    <meta charset=\\\"UTF-8\\\">\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n    <style>\\n        /* Unique CSS ID for the container */\\n        #UniqueReceiptDetailsContainer {\\n            text-align: right; /* Align the entire container text to the right */\\n            max-width: 300px; /* Set a max width to control the layout */\\n            font-family: Arial, sans-serif; /* Set a font for consistency */\\n            margin-right: 0; /* Ensure the container is aligned to the far right */\\n        }\\n\\n        /* Unique class for the table */\\n        .uniqueReceiptTable {\\n            border-collapse: collapse;\\n            width: 100%; /* Ensure the table takes full width */\\n            margin-top: 10px; /* Add some spacing at the top */\\n        }\\n\\n        /* Style for table cells */\\n        .uniqueReceiptTable td {\\n            font-size: 12px;\\n            text-align: right; /* Align text to the right within table cells */\\n            padding: 1px; /* Add some padding for better readability */\\n            white-space: nowrap; /* Prevent text from wrapping to the next line */\\n        }\\n    </style>\\n</head>\\n<body>\\n    <div id=\\\"UniqueReceiptDetailsContainer\\\">\\n        <table class=\\\"uniqueReceiptTable\\\">\\n            <tr>\\n                <td> Slip No:</td>\\n                <td>{{ doc.name }}</td>\\n            </tr>\\n            <tr>\\n                <td>Date:</td>\\n                <td>{{ doc.posting_date }}</td>\\n            </tr>\\n        </table>\\n    </div>\\n</body>\\n</html>\\n\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<style>\\n    .divider-line {\\n            border: none; /* Remove default border */\\n            height: 1px; /* Set the height of the line */\\n            background-color: #000; /* Set the color of the line */\\n            margin-top: 0; /* Add some space above the line */\\n            margin-bottom: 2px; /* Add some space below the line */\\n            width: 100%; /* Make the line span the full width */\\n            margin-left: auto; /* Center the line */\\n            margin-right: auto; /* Center the line */\\n        }\\n</style>\\n<hr class=\\\"divider-line\\\">\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<p><strong>Earnings</strong></p>\\n\"}, {\"